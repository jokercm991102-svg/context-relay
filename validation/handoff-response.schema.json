{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "current_state",
    "verified",
    "in_progress",
    "next_safe_action",
    "unknowns"
  ],
  "properties": {
    "current_state": {
      "type": "string"
    },
    "verified": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "in_progress": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_safe_action": {
      "type": "string"
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
